-- Top 10 Best IPOs
SELECT
    company,
    issue_price,
    listing_close,
    listing_gain,
    profit_loss
FROM ipo_data
ORDER BY listing_gain DESC
LIMIT 10;


-- Top 10 Worst IPOs
SELECT
    company,
    issue_price,
    listing_close,
    listing_gain,
    profit_loss
FROM ipo_data
ORDER BY listing_gain ASC
LIMIT 10;

















